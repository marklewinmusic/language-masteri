{
  "name": "ActivityProgress",
  "type": "object",
  "properties": {
    "activity_id": {
      "type": "string",
      "description": "ID of the activity"
    },
    "completions": {
      "type": "number",
      "default": 0
    },
    "unlocked": {
      "type": "boolean",
      "default": false
    },
    "date_selected": {
      "type": "string",
      "description": "Which date was chosen (moroccan or blonde)"
    }
  },
  "required": [
    "activity_id"
  ]
}