{
  "name": "PracticeResult",
  "type": "object",
  "properties": {
    "story_id": {
      "type": "string"
    },
    "exercise_type": {
      "type": "string",
      "enum": [
        "listening_image",
        "reorder_lines",
        "speak_sentence"
      ]
    },
    "completed": {
      "type": "boolean",
      "default": true
    },
    "attempts": {
      "type": "number",
      "default": 1
    }
  },
  "required": [
    "story_id",
    "exercise_type"
  ]
}