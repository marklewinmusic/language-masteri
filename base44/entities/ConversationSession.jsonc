{
  "name": "ConversationSession",
  "type": "object",
  "properties": {
    "story_id": {
      "type": "string"
    },
    "duration_seconds": {
      "type": "number"
    },
    "transcript": {
      "type": "string",
      "description": "Optional conversation transcript"
    },
    "completed": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "story_id"
  ]
}