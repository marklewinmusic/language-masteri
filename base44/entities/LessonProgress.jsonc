{
  "name": "LessonProgress",
  "type": "object",
  "properties": {
    "lesson_name": {
      "type": "string",
      "description": "Name of the lesson (e.g., ColorsLesson)"
    },
    "completed": {
      "type": "boolean",
      "default": false
    },
    "test_score": {
      "type": "number",
      "description": "Score on the test (percentage)"
    },
    "test_completed": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "lesson_name"
  ]
}