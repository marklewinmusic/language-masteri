{
  "name": "TodoProgress",
  "type": "object",
  "properties": {
    "todo_item_id": {
      "type": "string",
      "description": "ID of the TodoItem"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether this item is completed by the user"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this item was completed"
    }
  },
  "required": [
    "todo_item_id"
  ]
}